---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="/theatre-works.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>any</title>
    <meta
      name="description"
      content="Any uses five local hardcoded test videos in the original Theatre Works layout, ready to be swapped later for Cloudflare or Google Sheets data."
    />
    <style>
      @import '../components/CreditsPanel.css';
      @import '../components/VUMeter.css';
    </style>
  </head>
  <body>
    <div class="theatre-works">
      <div class="fixed-viewer">
        <div class="viewer-container">
          <div class="video-section full-width">
            {works.length === 0 ? (
              <div class="loading">
                <p>No works found</p>
              </div>
            ) : (
              <VideoGrid works={works} client:only="react" />
            )}
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
