---
import App from '../components/App';
import { loadSiteCms } from '../lib/cms/loadWorks';

export const prerender = false;

const cms = await loadSiteCms();
const { works, tags } = cms;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="/theatre-works.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>anyway</title>
    <meta
      name="description"
      content="Any — ambient music archive with video grid, tag search, and contact."
    />
  </head>
  <body>
    <div class="theatre-works">
      <div class="fixed-viewer">
        <div class="viewer-container">
          <div class="video-section full-width">
            {works.length === 0 ? (
              <div class="loading">
                <p>No works found</p>
              </div>
            ) : (
              <App works={works} tags={tags} client:only="react" />
            )}
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
